# ============================================================================
# Server configuration. Copy to `.env` and fill in. NEVER commit the real .env.
# ============================================================================

PORT=8080

# Public URL of THIS server once deployed (used to build OAuth redirect_uri).
# Locally: http://localhost:8080   On Render: https://your-service.onrender.com
PUBLIC_BASE_URL=http://localhost:8080

# Where to send the browser back after an OAuth connect completes.
# Flutter web dev server, or your deployed app URL.
APP_RETURN_URL=http://localhost:3000/#/accounts

# --- Supabase -------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key            # used only to validate user JWTs
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # bypasses RLS — server only, keep secret

# --- Token encryption (plan §5) ------------------------------------------
# 32-byte key, base64 or 64-char hex. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# --- Cloudinary -----------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Scheduler ------------------------------------------------------------
# true  => run an in-process node-cron loop every minute (needs an always-on
#          instance; Render free tier sleeps, so use Starter or a Cron Job).
# false => disable the loop and drive it externally by POSTing /internal/run-due
#          with header `x-cron-secret: $CRON_SECRET` (Render Cron Job / pg_cron).
SCHEDULER_ENABLED=true
CRON_SECRET=change-me

# --- Platform OAuth apps --------------------------------------------------
# Leave any pair blank to keep that platform in safe MOCK mode (the pipeline
# still runs end-to-end; publishing is simulated until you add real keys).

# Facebook + Instagram (one Meta app drives both)
FB_APP_ID=
FB_APP_SECRET=
FB_API_VERSION=v21.0

# Pinterest (API v5)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Twitter / X  (OAuth2 PKCE — paid API tier required to actually publish)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
